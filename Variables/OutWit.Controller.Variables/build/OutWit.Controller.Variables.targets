<Project>

  <!--
      Consumer-side targets for the OutWit.Controller.Variables NuGet package.
      Auto-imported into any csproj that PackageReferences this controller.

      Tier-1 controller: no external data assets. Only step is to copy this
      package's content/module/* into $(OutputPath)@Controllers\<Cfg>\variables.module\
      so the controller runtime can find Variables.dll, its Model dll, and the manifest.
  -->

  <PropertyGroup>
    <_OutWitVariablesModulePackageContent>$(MSBuildThisFileDirectory)..\content\module\</_OutWitVariablesModulePackageContent>
    <_OutWitVariablesModuleOutputDir>$(OutputPath)@Controllers\$(Configuration)\variables.module\</_OutWitVariablesModuleOutputDir>
  </PropertyGroup>

  <Target Name="OutWitCopyVariablesModule"
          AfterTargets="ResolveAssemblyReferences"
          BeforeTargets="Build"
          Condition="Exists('$(_OutWitVariablesModulePackageContent)')">
    <ItemGroup>
      <_OutWitVariablesFiles Include="$(_OutWitVariablesModulePackageContent)**\*" />
    </ItemGroup>
    <Copy
        SourceFiles="@(_OutWitVariablesFiles)"
        DestinationFiles="@(_OutWitVariablesFiles->'$(_OutWitVariablesModuleOutputDir)%(RecursiveDir)%(Filename)%(Extension)')"
        SkipUnchangedFiles="true"
        OverwriteReadOnlyFiles="true" />
    <Message Importance="Normal"
             Text="OutWit.Controller.Variables: staged module to '$(_OutWitVariablesModuleOutputDir)'." />
  </Target>

  <Target Name="OutWitResolveVariablesAssets"
          AfterTargets="OutWitCopyVariablesModule"
          Condition="Exists('$(_OutWitVariablesModuleOutputDir)controller.json')">
    <ResolveControllerAssetsTask
        ManifestPath="$(_OutWitVariablesModuleOutputDir)controller.json"
        OutputPath="$(OutputPath)@Controllers\$(Configuration)\" />
  </Target>

</Project>
