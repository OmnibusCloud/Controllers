<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
   <ControllerName>Matrices</ControllerName>
	<Version>1.0.2</Version>
	<Description>Matrix and vector operations including sparse representations and Gustavson multiplication.</Description>
	<Authors>OutWit</Authors>
	<Copyright>Copyright 2025 OutWit</Copyright>
	<PackageLicenseExpression>MIT</PackageLicenseExpression>
	<PackageTags>matrices;vectors;linear-algebra;sparse</PackageTags>
	<ControllerFeatures>dense-matrix;sparse-matrix;dense-vector;sparse-vector;gustavson-multiply</ControllerFeatures>
	<ControllerUseCases>Linear algebra;Sparse matrix multiplication;Scientific computing</ControllerUseCases>
  </PropertyGroup>

	<Import Project="..\..\Build\OutWit.Controller.Manifest.targets" />

  <ItemGroup>
    <PackageReference Include="OutWit.Engine.Data" Version="1.1.*" />
    <ProjectReference Include="..\OutWit.Controller.Matrices.Model\OutWit.Controller.Matrices.Model.csproj" />
  </ItemGroup>

  <!-- Step 10a pilot — declare rowMatrix.smat as an external data asset to
       end-to-end test the asset resolver pipeline (NuGet → manifest →
       gh-release://-resolver → cache → extract). The file is also currently
       embedded in Matrices.dll as a resource; both routes coexist during this
       pilot. Step 10b will remove the embedded copy and migrate Matrices code
       to load from the external file. -->
  <ItemGroup>
    <ControllerDataAsset Include="rowMatrix">
      <RuntimeIdentifier>any</RuntimeIdentifier>
      <Uri>gh-release://OmnibusCloud/Controllers/matrices-v1.0.2/rowMatrix.smat</Uri>
      <Sha256>bc2dc4d1e5bd6e3ba1a9e89f50d0ee5de72c11a1054d1707103ecfa492f84246</Sha256>
      <Size>98333</Size>
      <ExtractTo>Resources/</ExtractTo>
    </ControllerDataAsset>
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Properties\Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Properties\Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

	<ItemGroup>
		<MatricesModuleFiles Include="$(TargetDir)$(TargetName).dll" />
		<MatricesModuleFiles Include="$(TargetDir)$(TargetName).dll.config" Condition="Exists('$(TargetDir)$(TargetName).dll.config')" />
		<MatricesModuleFiles Include="$(TargetDir)$(TargetName).deps.json" />
		<MatricesModuleFiles Include="$(TargetDir)**\$(TargetName).resources.dll" />
      <MatricesModuleFiles Include="$(ControllerManifestOutputPath)" />
	</ItemGroup>

	<Target Name="PostBuild" AfterTargets="PostBuildEvent">
		<Copy SourceFiles="@(MatricesModuleFiles)" DestinationFolder="$(SolutionDir)@Controllers\$(Configuration)\matrices.module\" SkipUnchangedFiles="true" OverwriteReadOnlyFiles="true" />
	</Target>

	<Target Name="PackZip" AfterTargets="PostBuild">
		<MakeDir Directories="$(SolutionDir)@Zips\$(Configuration)\" />
		<ZipDirectory SourceDirectory="$(SolutionDir)@Controllers\$(Configuration)\matrices.module\"
		              DestinationFile="$(SolutionDir)@Zips\$(Configuration)\matrices.zip"
		              Overwrite="true" />
	</Target>

</Project>
