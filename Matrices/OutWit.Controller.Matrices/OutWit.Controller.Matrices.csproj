<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ControllerName>Matrices</ControllerName>
    <Version>1.0.2</Version>
    <Description>Matrix and vector operations including sparse representations and Gustavson multiplication.</Description>
    <Authors>OutWit</Authors>
    <Copyright>Copyright 2025 OutWit</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>matrices;vectors;linear-algebra;sparse;witengine;witcloud;controller</PackageTags>
    <ControllerFeatures>dense-matrix;sparse-matrix;dense-vector;sparse-vector;gustavson-multiply</ControllerFeatures>
    <ControllerUseCases>Linear algebra;Sparse matrix multiplication;Scientific computing</ControllerUseCases>

    <!-- Tier 2 controller packaging:
         - Don't include build output in lib/ — the DLLs aren't a runtime
           dependency of the consumer; they ship as content under content/module/
           and the consumer's build/.targets copies them to @Controllers/.
         - NoPackageAnalysis suppresses NuGet's "you're packing oddly" warnings.
         - TargetsForTfmSpecificContentInPackage hooks PackModuleContents into
           NuGet's per-tfm content gathering. -->
    <IsPackable>true</IsPackable>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <NoPackageAnalysis>true</NoPackageAnalysis>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);PackMatricesModuleContents</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <Import Project="..\..\Build\OutWit.Controller.Manifest.targets" />

  <ItemGroup>
    <PackageReference Include="OutWit.Engine.Data" Version="1.1.*" />
    <!-- Build-time task package: registers <ResolveControllerAssets> which the
         consumer-side targets file invokes. The Engine.Assets.MSBuild package
         is itself marked DevelopmentDependency, so by default 'build' assets
         are excluded for consumers. We force them ON so the consumer gets the
         <UsingTask> registration when it PackageReferences this controller. -->
    <PackageReference Include="OutWit.Engine.Assets.MSBuild" Version="1.0.*">
      <PrivateAssets>none</PrivateAssets>
      <IncludeAssets>build; buildTransitive</IncludeAssets>
    </PackageReference>
    <!-- Matrices.Model is published as its own NuGet package — consumers
         resolve it transitively. The Model DLL still appears in this
         controller's content/module/ folder (so the runtime layout under
         @Controllers/matrices.module/ has it), but on the dependency-graph
         side it flows as a proper <dependency> in the nuspec. -->
    <ProjectReference Include="..\OutWit.Controller.Matrices.Model\OutWit.Controller.Matrices.Model.csproj" />
  </ItemGroup>

  <!-- Consumer-side .targets (auto-imported via NuGet's build/<PackageId>.targets convention). -->
  <ItemGroup>
    <None Include="build\OutWit.Controller.Matrices.targets" Pack="true" PackagePath="build\" />
  </ItemGroup>

  <!-- Step 10a pilot — declare rowMatrix.smat as an external data asset to
       end-to-end test the asset resolver pipeline (NuGet → manifest →
       gh-release://-resolver → cache → extract). The file is also currently
       embedded in Matrices.dll as a resource; both routes coexist during this
       pilot. Step 10b will remove the embedded copy and migrate Matrices code
       to load from the external file. -->
  <ItemGroup>
    <ControllerDataAsset Include="rowMatrix">
      <RuntimeIdentifier>any</RuntimeIdentifier>
      <Uri>gh-release://OmnibusCloud/Controllers/matrices-v1.0.2/rowMatrix.smat</Uri>
      <Sha256>bc2dc4d1e5bd6e3ba1a9e89f50d0ee5de72c11a1054d1707103ecfa492f84246</Sha256>
      <Size>98333</Size>
      <ExtractTo>Resources/</ExtractTo>
    </ControllerDataAsset>
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Properties\Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Properties\Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

	<ItemGroup>
		<MatricesModuleFiles Include="$(TargetDir)$(TargetName).dll" />
		<MatricesModuleFiles Include="$(TargetDir)$(TargetName).dll.config" Condition="Exists('$(TargetDir)$(TargetName).dll.config')" />
		<MatricesModuleFiles Include="$(TargetDir)$(TargetName).deps.json" />
		<MatricesModuleFiles Include="$(TargetDir)**\$(TargetName).resources.dll" />
      <MatricesModuleFiles Include="$(ControllerManifestOutputPath)" />
	</ItemGroup>

	<Target Name="PostBuild" AfterTargets="PostBuildEvent">
		<Copy SourceFiles="@(MatricesModuleFiles)" DestinationFolder="$(SolutionDir)@Controllers\$(Configuration)\matrices.module\" SkipUnchangedFiles="true" OverwriteReadOnlyFiles="true" />
	</Target>

	<Target Name="PackZip" AfterTargets="PostBuild">
		<MakeDir Directories="$(SolutionDir)@Zips\$(Configuration)\" />
		<ZipDirectory SourceDirectory="$(SolutionDir)@Controllers\$(Configuration)\matrices.module\"
		              DestinationFile="$(SolutionDir)@Zips\$(Configuration)\matrices.zip"
		              Overwrite="true" />
	</Target>

	<!-- Hook into NuGet's per-TFM content gathering — collects the .module/
	     contents (which the PostBuild target above just staged) and packs them
	     under content/module/ in the nupkg. The consumer's build/.targets then
	     fans them out to its @Controllers/<Config>/matrices.module/.

	     Also writes an empty lib/<tfm>/_._ marker so NuGet considers the
	     package compatible with net10.0 consumers (without IncludeBuildOutput
	     there's otherwise no framework-specific content at all and NuGet
	     refuses to install). This is the standard analyzer/build-tool pattern. -->
	<Target Name="PackMatricesModuleContents" DependsOnTargets="PostBuild;PackZip">
		<PropertyGroup>
			<_MatricesEmptyLibMarker>$(IntermediateOutputPath)_._</_MatricesEmptyLibMarker>
		</PropertyGroup>
		<WriteLinesToFile File="$(_MatricesEmptyLibMarker)" Lines="" Overwrite="true" />
		<ItemGroup>
			<_PackedMatricesModuleFiles Include="$(SolutionDir)@Controllers\$(Configuration)\matrices.module\**\*" />
			<TfmSpecificPackageFile Include="@(_PackedMatricesModuleFiles)">
				<PackagePath>content/module/%(RecursiveDir)%(Filename)%(Extension)</PackagePath>
			</TfmSpecificPackageFile>
			<TfmSpecificPackageFile Include="$(_MatricesEmptyLibMarker)">
				<PackagePath>lib/$(TargetFramework)/_._</PackagePath>
			</TfmSpecificPackageFile>
		</ItemGroup>
	</Target>

</Project>
