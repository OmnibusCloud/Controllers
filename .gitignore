# Ignore Visual Studio temporary files, build results, and
# files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

#Nuget
*.nupkg
*.snupkg

# Mono Auto Generated Files
mono_crash.*

#NuGet Packages
packages/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2019/2022
.vscode/
.vs/
.vscode/settings.json

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# C# Project files
project.lock.json
project.fragment.lock.json
artifacts/

# Local build artifacts: staged controller modules, packed zips,
# pack-render-prereqs output, and the @Publish/GoldenCandidates/
# folder where every Render.Tests run stages its actual render output +
# side-by-side diff for visual inspection. Not part of source.
@Controllers/
@Zips/
@Publish/
dist/

# Local-only test fixtures: large .blend scenes, golden renders,
# blender / ffmpeg runtime binaries. Tests `Assert.Ignore` when
# these are missing — CI stays green, but a local dev with these
# folders populated can run the full Render.Tests suite. See
# Render/OutWit.Controller.Render.Tests/README.md for layout.
@Prerequisites/
@Data/

# Per-project test output (NUnit/MSTest trx files, coverage reports)
TestResults/

# Auto-generated files by Visual Studio
*.dbmdl
*.pdb
*.cache
*.ilk
*.log
*.userprefs
*.tlog
*.vspscc
*.vspx

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Entity Framework Migrations
Migrations/

# Rider specific folders
.idea/
.idea_modules/

# JetBrains Rider
.idea/
.idea_modules/
