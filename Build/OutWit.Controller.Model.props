<!--
    Build/OutWit.Controller.Model.props
    Imported manually by each Controller Model csproj. Models are regular
    library NuGets (lib/<tfm>/<assembly>.dll). Per-Model csprojs only need
    ControllerName, Version, Description, PackageTags.

    Usage:

      <Project Sdk="Microsoft.NET.Sdk">
        <Import Project="..\..\Build\OutWit.Controller.Model.props" />
        <PropertyGroup>
          <ControllerName>Foo</ControllerName>
          <Version>1.0.0</Version>
          <Description>...</Description>
          <PackageTags>...</PackageTags>
        </PropertyGroup>
        <Import Project="..\..\Build\OutWit.Controller.Model.targets" />
      </Project>
-->
<Project>

  <PropertyGroup>
    <!-- Solution-relative paths in OutWit.Controller.Model.targets (ModelPostBuild)
         used to assume $(SolutionDir) was set by `dotnet build OutWit.slnx`.
         Agent-driven workflows invoke `dotnet build ./X.Model.csproj` directly
         where $(SolutionDir) is undefined. Resolve the solution root explicitly
         by walking up to OutWit.slnx so both invocation styles work. -->
    <SolutionDir Condition="'$(SolutionDir)' == '' Or '$(SolutionDir)' == '*Undefined*'">$([MSBuild]::GetDirectoryNameOfFileAbove($(MSBuildProjectDirectory), 'OutWit.slnx'))\</SolutionDir>
  </PropertyGroup>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>

    <!-- PackageId inherits the csproj filename by default
         (OutWit.Controller.<Name>.Model.csproj -> OutWit.Controller.<Name>.Model). -->
    <Authors>Dmitry Ratner</Authors>
    <Company>OutWit</Company>
    <Copyright>Copyright © $([System.DateTime]::UtcNow.Year) Dmitry Ratner</Copyright>
    <PackageProjectUrl>https://witengine.io/</PackageProjectUrl>
    <RepositoryUrl>https://github.com/OmnibusCloud/Controllers</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageIcon>WitEngine-logo.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!-- Standard library shape: lib/<tfm>/<assembly>.dll. No content tricks. -->
    <GeneratePackageOnBuild Condition=" '$(Configuration)' == 'Release' ">true</GeneratePackageOnBuild>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
  </PropertyGroup>

  <!-- Common runtime deps every Model takes. -->
  <ItemGroup>
    <PackageReference Include="OutWit.Common" Version="1.3.2" />
    <PackageReference Include="OutWit.Common.MemoryPack" Version="1.1.4" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="10.0.201">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <None Include="LICENSE"             Pack="true" PackagePath="\" />
    <None Include="WitEngine-logo.png"  Pack="true" PackagePath="\" />
    <None Include="README.md"           Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
