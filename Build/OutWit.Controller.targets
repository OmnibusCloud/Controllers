<!--
    Build/OutWit.Controller.targets
    Imported manually by each controller's main csproj after the
    OutWit.Controller.props import + the per-controller PropertyGroup.
    Provides: manifest emission, .module/ staging, .zip packing, and
    nupkg content/module/ packaging.
-->
<Project>

  <Import Project="$(MSBuildThisFileDirectory)OutWit.Controller.Manifest.targets" />

  <!-- Derived properties — computed here (rather than in OutWit.Controller.props)
       because they depend on the per-csproj <ControllerName>, which isn't set
       yet at the moment props is parsed. ToLowerInvariant matches the existing
       matrices.module / renderdcc.module / etc. naming. -->
  <PropertyGroup>
    <ControllerModuleName>$(ControllerName.ToLowerInvariant()).module</ControllerModuleName>
    <ControllerZipName>$(ControllerName.ToLowerInvariant()).zip</ControllerZipName>
    <ControllerModuleOutputDir>$(SolutionDir)@Controllers\$(Configuration)\$(ControllerModuleName)\</ControllerModuleOutputDir>
    <ControllerZipOutputDir>$(SolutionDir)@Zips\$(Configuration)\</ControllerZipOutputDir>
  </PropertyGroup>

  <!-- The set of build outputs that go into a controller's .module/ folder.
       Companion Model csprojs add their own DLL via OutWit.Controller.Model.targets. -->
  <ItemGroup>
    <ControllerModuleFile Include="$(TargetDir)$(TargetName).dll" />
    <ControllerModuleFile Include="$(TargetDir)$(TargetName).dll.config" Condition="Exists('$(TargetDir)$(TargetName).dll.config')" />
    <ControllerModuleFile Include="$(TargetDir)$(TargetName).deps.json" />
    <ControllerModuleFile Include="$(TargetDir)**\$(TargetName).resources.dll" />
    <ControllerModuleFile Include="$(ControllerManifestOutputPath)" />
  </ItemGroup>

  <!-- Stages the controller's outputs into $(SolutionDir)@Controllers/<Cfg>/<name>.module/.
       Mirrors the legacy WitEngine layout so existing tooling keeps working. -->
  <Target Name="ControllerPostBuild" AfterTargets="PostBuildEvent">
    <Copy SourceFiles="@(ControllerModuleFile)"
          DestinationFolder="$(ControllerModuleOutputDir)"
          SkipUnchangedFiles="true"
          OverwriteReadOnlyFiles="true" />
  </Target>

  <!-- Convention: any file under <ProjectDir>/Resources/ at build time gets
       staged into <module>/Resources/ with the same relative path. This is
       what makes ProjectReference-based test scenarios complete — the
       adapter's runtime resource loader can find the file at
       <assembly-dir>/Resources/<file> just like it would after a consumer
       installed the published nupkg + ran ResolveControllerAssetsTask.

       For Tier-2 controllers, the same files are also declared as
       <ControllerDataAsset> (with gh-release:// Uri) so published consumers
       fetch them from a GitHub Release rather than carrying them inline.
       Local dev / in-solution tests use this staging path; consumers use
       the asset resolver. Both end up with the same on-disk layout.

       Skipped silently when the controller has no Resources/ folder. -->
  <ItemGroup>
    <ControllerSourceResourceFile Include="$(ProjectDir)Resources\**\*"
                                  Condition="Exists('$(ProjectDir)Resources')" />
  </ItemGroup>

  <Target Name="ControllerStageSourceResources"
          AfterTargets="ControllerPostBuild"
          Condition="@(ControllerSourceResourceFile->Count()) &gt; 0">
    <Copy SourceFiles="@(ControllerSourceResourceFile)"
          DestinationFiles="@(ControllerSourceResourceFile->'$(ControllerModuleOutputDir)Resources\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"
          OverwriteReadOnlyFiles="true" />
  </Target>

  <!-- Zips the staged module dir into $(SolutionDir)@Zips/<Cfg>/<name>.zip.
       Used by the BlobCacheService path on WitCloud server-side. -->
  <Target Name="ControllerPackZip" AfterTargets="ControllerPostBuild">
    <MakeDir Directories="$(ControllerZipOutputDir)" />
    <ZipDirectory SourceDirectory="$(ControllerModuleOutputDir)"
                  DestinationFile="$(ControllerZipOutputDir)$(ControllerZipName)"
                  Overwrite="true" />
  </Target>

  <!-- Packs the staged module dir into nupkg's content/module/ + writes an
       empty lib/<tfm>/_._ marker so NuGet considers the package compatible
       with consumer projects (without IncludeBuildOutput=false there'd be
       nothing in lib/ otherwise). Registered into pack via
       TargetsForTfmSpecificContentInPackage (set in OutWit.Controller.props). -->
  <Target Name="ControllerPackModuleContents" DependsOnTargets="ControllerPostBuild;ControllerPackZip">
    <PropertyGroup>
      <_EmptyLibMarker>$(IntermediateOutputPath)_._</_EmptyLibMarker>
    </PropertyGroup>
    <WriteLinesToFile File="$(_EmptyLibMarker)" Lines="" Overwrite="true" />
    <ItemGroup>
      <_PackedModuleFile Include="$(ControllerModuleOutputDir)**\*" />
      <TfmSpecificPackageFile Include="@(_PackedModuleFile)">
        <PackagePath>content/module/%(RecursiveDir)%(Filename)%(Extension)</PackagePath>
      </TfmSpecificPackageFile>
      <TfmSpecificPackageFile Include="$(_EmptyLibMarker)">
        <PackagePath>lib/$(TargetFramework)/_._</PackagePath>
      </TfmSpecificPackageFile>
    </ItemGroup>
  </Target>

</Project>
